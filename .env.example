# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="AQ.Ab8RN6Jwic7glYHaQBRpJ8I1HUC9eIBxM4mFd3LJuO7WLlTEQg"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# NODEMAILER SMTP SECURE EMAIL OUTBOX CONFIGURATION
# To use a genuine Gmail/Workspace SMTP outbox:
# 1. SMTP_HOST: smtp.gmail.com (or your private SMTP relay)
# 2. SMTP_PORT: 587 (for STARTTLS) or 465 (for SSL / secure SMTPS)
# 3. SMTP_USER: registered Google Workspace email (e.g., biotechagro.digital@gmail.com)
# 4. SMTP_PASS: a secure Google "App Password" generated under Google Account 2-Step Verification
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="biotechagro.digital@gmail.com"
SMTP_PASS="YOUR_SECURE_GOOGLE_APP_PASSWORD"
SMTP_SENDER_NAME="Biotech-Agro Admin Control"

# LIVE PRODUCTION ENVIRONMENT BYPASSES (Vercel & stateless cloud publishing)
# 1. ADMIN_PASSWORD: Set this to dry-run or lock down your admin passcode without writing back to a database.
# 2. ADMIN_EMAIL: Set this to overwrite the recipient of reset codes, inquiries, and alerts.
ADMIN_PASSWORD="mycoadmin_secure_pass"
ADMIN_EMAIL="biotechagro.digital@gmail.com"

